@prefix ns1: <http://light9.bigasterisk.com/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://light9.bigasterisk.com/show/dance2015/song1> ns1:curve <http://light9.bigasterisk.com/show/dance2015/song1/curve-15>,
        <http://light9.bigasterisk.com/show/dance2015/song1/curve-16>,
        <http://light9.bigasterisk.com/show/dance2015/song1/curve-17>,
        <http://light9.bigasterisk.com/show/dance2015/song1/curve-18> ;
    ns1:effect <http://light9.bigasterisk.com/show/dance2015/song1/effect-1>,
        <http://light9.bigasterisk.com/show/dance2015/song1/effect-2>,
        <http://light9.bigasterisk.com/show/dance2015/song1/effect-3>,
        <http://light9.bigasterisk.com/show/dance2015/song1/effect-4> .

<http://light9.bigasterisk.com/show/dance2015/song1/curve-15> a ns1:Curve ;
    rdfs:label "full" .

<http://light9.bigasterisk.com/show/dance2015/song1/curve-16> a ns1:Curve ;
    rdfs:label "lowstage" .

<http://light9.bigasterisk.com/show/dance2015/song1/curve-17> a ns1:Curve ;
    rdfs:label "song1" .

<http://light9.bigasterisk.com/show/dance2015/song1/curve-18> a ns1:Curve ;
    rdfs:label "houseside" .

<http://light9.bigasterisk.com/show/dance2015/song1/effect-1> a ns1:Effect ;
    rdfs:label "full" ;
    ns1:code "env = <http://light9.bigasterisk.com/show/dance2015/song1/curve-15>",
        "out = <http://light9.bigasterisk.com/show/dance2015/sub/full> * env" .

<http://light9.bigasterisk.com/show/dance2015/song1/effect-2> a ns1:Effect ;
    rdfs:label "lowstage" ;
    ns1:code "env = <http://light9.bigasterisk.com/show/dance2015/song1/curve-16>",
        "out = <http://light9.bigasterisk.com/show/dance2015/sub/lowstage> * env" .

<http://light9.bigasterisk.com/show/dance2015/song1/effect-3> a ns1:Effect ;
    rdfs:label "song1" ;
    ns1:code "env = <http://light9.bigasterisk.com/show/dance2015/song1/curve-17>",
        "out = <http://light9.bigasterisk.com/show/dance2015/sub/song1> * env" .

<http://light9.bigasterisk.com/show/dance2015/song1/effect-4> a ns1:Effect ;
    rdfs:label "houseside" ;
    ns1:code "env = <http://light9.bigasterisk.com/show/dance2015/song1/curve-18>",
        "out = <http://light9.bigasterisk.com/show/dance2015/sub/houseside> * env" .

