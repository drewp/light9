<http://light9.bigasterisk.com/show/dance2015/song16/effect-4> ns1:code "env = <http://light9.bigasterisk.com/show/dance2015/song16/curve-9>",
        "music = curve(<http://light9.bigasterisk.com/show/dance2015/song16music>, t+.05)",
        "out = <http://light9.bigasterisk.com/show/dance2015/sub/full> * music * env" .

