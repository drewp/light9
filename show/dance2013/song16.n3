    rdfs:label "backchase" ;
    ns1:expression "backchase_env(t) * chase(t, names=backchase, ontime=60./74/2, offset=0.0)" .

<http://light9.bigasterisk.com/show/dance2013/song16/subterm/11> a ns1:Subterm ;
    rdfs:label "pulserainbow" ;
    ns1:expression "pulserainbow_env(t) * hsv(t*60./137,1,1)" .

<http://light9.bigasterisk.com/show/dance2013/song16/subterm/12> a ns1:Subterm ;
    rdfs:label "bumpyhues" ;
    ns1:expression "bumpyhues_env(t) * hsv(t*60/106,.4,1)*(.7+nsin(t*60/106*3))" .

<http://light9.bigasterisk.com/show/dance2013/song16/subterm/13> a ns1:Subterm ;
    rdfs:label "" ;
    ns1:expression "chase150(t)*chase(t, names=scoop, ontime=0.5/2, offset=0.0)" .

