@prefix ns1: <http://light9.bigasterisk.com/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://light9.bigasterisk.com/show/dance2013/song17> ns1:subterm <http://light9.bigasterisk.com/show/dance2013/song17/subterm/0>,
        <http://light9.bigasterisk.com/show/dance2013/song17/subterm/1>,
        <http://light9.bigasterisk.com/show/dance2013/song17/subterm/2>,
        <http://light9.bigasterisk.com/show/dance2013/song17/subterm/3>,
        <http://light9.bigasterisk.com/show/dance2013/song17/subterm/4>,
        <http://light9.bigasterisk.com/show/dance2013/song17/subterm/5>,
        <http://light9.bigasterisk.com/show/dance2013/song17/subterm/6> .

<http://light9.bigasterisk.com/show/dance2013/song17/subterm/0> a ns1:Subterm ;
    rdfs:label "song17getup" ;
    ns1:expression "song17getup(t)" ;
    ns1:sub <http://light9.bigasterisk.com/show/dance2013/sub/song17getup> .

<http://light9.bigasterisk.com/show/dance2013/song17/subterm/1> a ns1:Subterm ;
    rdfs:label "patio" ;
    ns1:expression "patio(t)" ;
    ns1:sub <http://light9.bigasterisk.com/show/dance2013/sub/patio> .

<http://light9.bigasterisk.com/show/dance2013/song17/subterm/2> a ns1:Subterm ;
    rdfs:label "houseside" ;
    ns1:expression "houseside(t)" ;
    ns1:sub <http://light9.bigasterisk.com/show/dance2013/sub/houseside> .

<http://light9.bigasterisk.com/show/dance2013/song17/subterm/3> a ns1:Subterm ;
    rdfs:label "full" ;
    ns1:expression "full(t)" ;
    ns1:sub <http://light9.bigasterisk.com/show/dance2013/sub/full> .

<http://light9.bigasterisk.com/show/dance2013/song17/subterm/4> a ns1:Subterm ;
    rdfs:label "upscoop" ;
    ns1:expression "upscoop(t)" ;
    ns1:sub <http://light9.bigasterisk.com/show/dance2013/sub/upscoop> .

<http://light9.bigasterisk.com/show/dance2013/song17/subterm/5> a ns1:Subterm ;
    rdfs:label "backchase" ;
    ns1:expression "backchase_env(t) * chase(t, names=backchase, ontime=60./134/2, offset=0.0)" .

<http://light9.bigasterisk.com/show/dance2013/song17/subterm/6> a ns1:Subterm ;
    rdfs:label "cycpong" ;
    ns1:expression "cycpong_env(t) * chase(t, names=cycpong, ontime=60./102.-.2, offset=0.2)" .

