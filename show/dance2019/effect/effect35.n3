effect:effect35 a :Effect; rdfs:label "parpurple"; :publishAttr :strength; :setting effect:effect35_set0, effect:effect35_set1, effect:effect35_set2, effect:effect35_set3 .
effect:effect35_set0 :device dev:par1; :deviceAttr :color; :scaledValue "#ff00ae" .
effect:effect35_set1 :device dev:par3; :deviceAttr :color; :scaledValue "#ff0073" .
effect:effect35_set2 :device dev:par4; :deviceAttr :color; :scaledValue "#ff00ff" .
effect:effect35_set3 :device dev:par7; :deviceAttr :color; :scaledValue "#ff00fb" .
