effect:effect40 a :Effect; rdfs:label "song11center"; :publishAttr :strength;
     :setting effect:effect40_set0, effect:effect40_set1, effect:effect40_set2 .
effect:effect40_set0 :device dev:strip2; :deviceAttr :color; :scaledValue "#00087f" .
effect:effect40_set1 :device dev:strip3; :deviceAttr :color; :scaledValue "#1100ff" .
effect:effect40_set2 :device dev:strip1; :deviceAttr :color; :scaledValue "#060073" .
